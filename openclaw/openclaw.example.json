{
  "gateway": {
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/deepseek/deepseek-v4-flash"
      }
    }
  },
  "plugins": {
    "entries": {
      "openrouter": {
        "enabled": true
      }
    }
  },
  "messages": {
    "statusReactions": {
      "enabled": true,
      "emojis": {
        "done": "white_check_mark",
        "error": "x"
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.4.26"
  },
  "channels": {
    "slack": {
      "name": "single-brain",
      "enabled": true,
      "botToken": "YOUR_SLACK_BOT_TOKEN",
      "appToken": "YOUR_SLACK_APP_TOKEN",
      "ackReaction": "eyes",
      "healthMonitor": {
        "enabled": false
      }
    },
    "telegram": {
      "name": "single-brain",
      "enabled": true,
      "botToken": "YOUR_TELEGRAM_BOT_TOKEN",
      "reactionLevel": "extensive",
      "healthMonitor": {
        "enabled": false
      }
    }
  }
}
