# Single Brain — environment variables template
# Copy to .env and fill in values. Never commit .env.

TZ=America/New_York

# OpenClaw gateway auth token (auto-generated; keep secret)
OPENCLAW_GATEWAY_TOKEN=

# OpenRouter API keys — create two separate keys for per-agent tracking
# Dashboard: https://openrouter.ai/settings/keys
# Suggested names: "single-brain-openclaw" and "single-brain-hermes"
OPENCLAW_OPENROUTER_API_KEY=
HERMES_OPENROUTER_API_KEY=

# Telegram (used by watchdog + notifications)
TELEGRAM_USER_ID=

# Slack workspace identifiers (used for reference/docs)
SLACK_TEAM_ID=
SLACK_USER_ID=
